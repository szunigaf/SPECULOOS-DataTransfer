#!/bin/csh
# SPECULOOS Data Transfer - Credentials Configuration for C Shell Scripts
# Copy this file to .credentials.csh and fill in your actual credentials
# NEVER commit the .credentials.csh file to version control!

# =============================================================================
# TELESCOPE CONFIGURATION
# =============================================================================
# Telescope name: Io, Europa, Ganymede, or Callisto
setenv TELESCOPE_NAME "Callisto"

# Base directory for this telescope's data transfer operations
setenv TELESCOPE_BASE_DIR "~/ESO_data_transfer/Callisto_Astra"

# Mounting point of the Windows control PC directory on the Hub
setenv ACP_LOCAL_PATH "${TELESCOPE_BASE_DIR}/Astra_mount"

# Data folder on the Hub for temporary data storage (work directory)
setenv DATA_DIR "${TELESCOPE_BASE_DIR}/workdir"

# Log folder on the Hub
setenv LOG_DIR "${TELESCOPE_BASE_DIR}/Logs"

# Folder on the Hub where ESO will grab the formatted data
# Format: /home/eso/data_transfer/<telescope_lowercase>
setenv ESO_DIR "/home/eso/data_transfer/callisto"

# Path to Python scripts (astrometry_spirit.py, headerfix.py, mail_alert.py)
setenv PYTHON_SCRIPTS_PATH "${TELESCOPE_BASE_DIR}"

# =============================================================================
# CAMBRIDGE SERVER CREDENTIALS
# =============================================================================
setenv CAMBRIDGE_SERVER_USER "speculoos"
setenv CAMBRIDGE_SERVER_HOST "appcs.ra.phy.cam.ac.uk"
setenv CAMBRIDGE_SERVER_PASSWORD "your_ssh_password_here"
# Path format: /appct/data/SPECULOOSPipeline/Observations/<TelescopeName>/.
setenv CAMBRIDGE_SERVER_PATH "/appct/data/SPECULOOSPipeline/Observations/Callisto/."

# =============================================================================
# WINDOWS CONTROL PC CREDENTIALS
# =============================================================================
setenv CONTROL_PC_USER "speculoos"
setenv CONTROL_PC_PASSWORD "c0ntrolPC-04"
setenv CONTROL_PC_IP "172.16.0.202"
setenv CONTROL_PC_PATH "/Documents/astra/images/"

# =============================================================================
# EMAIL CONFIGURATION (used by mail_alert.py via environment variables)
# =============================================================================
setenv SMTP_SERVER "smtp.hermes.cam.ac.uk:587"
setenv SMTP_LOGIN "your_username_here"
setenv SMTP_PASSWORD "your_password_here"
setenv EMAIL_FROM "your_email@cam.ac.uk"
setenv EMAIL_TO "recipient@cam.ac.uk"
# Optional: Add CC recipients separated by commas
# setenv EMAIL_CC "cc_recipient1@cam.ac.uk,cc_recipient2@cam.ac.uk"
