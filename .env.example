# SPECULOOS Data Transfer - Environment Variables Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to version control!

# =============================================================================
# EMAIL CONFIGURATION (for mail_alert.py)
# =============================================================================
SMTP_SERVER=smtp.hermes.cam.ac.uk:587
SMTP_LOGIN=your_username_here
SMTP_PASSWORD=your_password_here
EMAIL_FROM=your_email@cam.ac.uk
EMAIL_TO=recipient@cam.ac.uk
# Optional: Add CC recipients separated by commas
# EMAIL_CC=cc_recipient1@cam.ac.uk,cc_recipient2@cam.ac.uk

# =============================================================================
# CAMBRIDGE SERVER CONFIGURATION (for transfer_Astra.csh)
# =============================================================================
CAMBRIDGE_SERVER_USER=speculoos
CAMBRIDGE_SERVER_HOST=appcs.ra.phy.cam.ac.uk
CAMBRIDGE_SERVER_PASSWORD=your_ssh_password_here
CAMBRIDGE_SERVER_PATH=/appct/data/SPECULOOSPipeline/Observations/Callisto/.

# =============================================================================
# WINDOWS CONTROL PC CONFIGURATION (for transfer_Astra.csh)
# =============================================================================
CONTROL_PC_USER=speculoos
CONTROL_PC_PASSWORD=your_password_here
CONTROL_PC_IP=172.16.0.202
CONTROL_PC_PATH=/Documents/astra/images/
